VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Frontend runtime
VITE_API_URL=http://localhost:5000
VITE_PULSE_BASE_URL=http://localhost:8083
VITE_PULSE_FUNCTIONS_BASE_URL=https://your-pulse-project.supabase.co/functions/v1

# Pulse integration
PULSE_SSO_URL=http://localhost:8083/auth/sso
PULSE_FUNCTIONS_BASE_URL=https://your-pulse-project.supabase.co/functions/v1
