NODE_ENV=development
PORT=5000
SESSION_SECRET=your-long-session-secret
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://tuweb-ai.com,https://www.tuweb-ai.com
VITE_API_URL=http://localhost:5000

# Supabase bootstrap
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_ACCESS_TOKEN=your-supabase-access-token
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Frontend runtime
VITE_AUTH_REDIRECT_BASE_URL=https://tuweb-ai.com
VITE_PULSE_BASE_URL=http://localhost:8083
VITE_PULSE_FUNCTIONS_BASE_URL=https://your-pulse-project.supabase.co/functions/v1

# Pulse integration
PULSE_SSO_URL=https://pulse.tuweb-ai.com/auth/sso
PULSE_FUNCTIONS_BASE_URL=https://your-pulse-project.supabase.co/functions/v1
TUWEBAI_WEBHOOK_SECRET=replace-with-the-shared-pulse-secret

# Internal auth / logging
API_KEY=your-internal-api-key
LOG_SINK_URL=
LOG_SINK_API_KEY=
LOG_SINK_TIMEOUT_MS=2000
ENFORCE_SERVER_AUTH=false

# Contact / SMTP / Brevo
CONTACT_TO_EMAIL=hola@tuweb-ai.com
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
SMTP_FROM_EMAIL=no-reply@tuweb-ai.com
SMTP_FROM_NAME=TuWeb.ai
NEWSLETTER_FROM_EMAIL=news@tuweb-ai.com
BREVO_API_KEY=your-brevo-api-key
BREVO_API_BASE_URL=https://api.brevo.com/v3
BREVO_NEWSLETTER_LIST_ID=1
BREVO_WEBHOOK_TOKEN=your-brevo-webhook-token

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=your-mercadopago-access-token
MERCADOPAGO_WEBHOOK_SECRET=your-mercadopago-webhook-secret

# Google Analytics 4
GA_MEASUREMENT_ID=
