{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build:frontend": "vite build && node scripts/prerender-blog-pages.mjs",
    "build:backend": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist-server",
    "build": "npm run build:frontend",
    "build:all": "npm run build:backend && npm run build:frontend",
    "start": "cross-env NODE_ENV=production node dist-server/index.js",
    "check": "npm run check:client && npm run check:server",
    "check:client": "tsc --noEmit",
    "check:server": "tsc --noEmit -p tsconfig.server.json",
    "check:no-native-dialogs": "node scripts/check-no-native-dialogs.mjs",
    "lint": "npm run lint:client && npm run lint:server",
    "lint:client": "eslint client/src --ext .ts,.tsx",
    "lint:server": "eslint server --ext .ts",
    "lint:no-native-dialogs": "eslint client/src --ext .ts,.tsx --max-warnings=0",
    "db:push": "drizzle-kit push",
    "dev": "cross-env CHOKIDAR_USEPOLLING=1 tsx watch --include server --include scripts --include docs-blogs server/index.ts",
    "dev:backend": "cross-env CHOKIDAR_USEPOLLING=1 tsx watch --include server --include scripts --include docs-blogs server/index.ts",
    "dev:frontend": "vite",
    "dev:log-sink": "node scripts/log-sink.mjs",
    "dev:all": "concurrently -k -n backend,frontend -c cyan,magenta \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:enterprise": "concurrently -k -n backend,frontend,logsink -c cyan,magenta,yellow \"npm:dev:backend\" \"npm:dev:frontend\" \"npm:dev:log-sink\"",
    "perf:baseline": "node scripts/perf-baseline.mjs",
    "perf:budget": "node scripts/perf-budget.mjs",
    "perf:verify": "node scripts/perf-verify-production.mjs",
    "smoke": "node scripts/smoke.mjs",
    "smoke:auth": "cross-env SMOKE_ENFORCE_SERVER_AUTH=1 node scripts/smoke.mjs",
    "test": "npm run smoke",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "supabase:migrate": "npx tsx scripts/supabase-run-migrations.ts",
    "supabase:hardening": "npx tsx scripts/supabase-apply-security-hardening.ts",
    "supabase:backfill:users": "npx tsx scripts/backfill-users-to-supabase.ts",
    "supabase:backfill:newsletter": "npx tsx scripts/backfill-newsletter-to-supabase.ts",
    "supabase:backfill:testimonials": "npx tsx scripts/backfill-testimonials-to-supabase.ts",
    "supabase:backfill:projects-support": "npx tsx scripts/backfill-projects-support-to-supabase.ts",
    "supabase:sync:auth": "npx tsx scripts/supabase-sync-auth-identities.ts",
    "supabase:init:storage": "npx tsx scripts/supabase-init-storage.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.1",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-collapsible": "^1.1.1",
    "@radix-ui/react-context-menu": "^2.2.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-hover-card": "^1.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-menubar": "^1.1.2",
    "@radix-ui/react-navigation-menu": "^1.2.1",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-radio-group": "^1.2.1",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slider": "^1.2.1",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-toggle": "^1.1.0",
    "@radix-ui/react-toggle-group": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@supabase/supabase-js": "^2.101.1",
    "@tanstack/react-query": "^5.60.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/react-helmet": "^6.1.11",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "date-fns": "^3.6.0",
    "dotenv": "^17.2.0",
    "embla-carousel-react": "^8.3.0",
    "esbuild": "^0.25.6",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.1",
    "firebase-admin": "^13.6.1",
    "framer-motion": "^10.12.5",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.453.0",
    "memorystore": "^1.6.7",
    "mercadopago": "^2.8.0",
    "nodemailer": "^7.0.5",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-helmet": "^6.1.0",
    "react-hook-form": "^7.53.1",
    "react-icons": "^5.4.0",
    "react-resizable-panels": "^2.1.4",
    "react-router-dom": "^7.5.0",
    "react-scroll": "^1.9.3",
    "react-slick": "^0.30.3",
    "slick-carousel": "^1.8.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^3.4.14",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "vaul": "^1.1.0",
    "vite": "^5.4.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/express-session": "^1.18.0",
    "@types/helmet": "^0.0.48",
    "@types/node": "20.16.11",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.35.0",
    "typescript": "5.6.3"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.8"
  }
}
